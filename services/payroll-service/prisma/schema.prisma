generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model PayrollJob {
  id             String   @id @default(uuid())
  employerId     String
  fromWalletId   String   // The Employer Ledger Wallet ID To Debit
  status         PayrollStatus @default(PENDING)
  totalAmount    Decimal
  totalUsers     Int

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items PayrollItem[]
}

model PayrollItem {
  id           String   @id @default(uuid())
  payrollJobId String

  userId       String
  walletId     String   // The Employee Ledger Wallet ID To Credit
  amount       Decimal
  currency     String

  status       PayrollStatus @default(PENDING)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payrollJob PayrollJob @relation(fields: [payrollJobId], references: [id])

  @@index([payrollJobId])
}

enum PayrollStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
