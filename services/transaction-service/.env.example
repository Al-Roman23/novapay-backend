# NovaPay Transaction Service - Environment Template
# Duplicate This File To .env To Configure For Local Development

# 🛡️ Service Boundary & Connectivity
PORT=3002
NODE_ENV=development

# 🏢 Database Persistence (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transaction_service_db?schema=public"

# ⛓️ Service Mesh URLs (Internal Docker Network)
ACCOUNT_SERVICE_URL="http://account-service:3001"
LEDGER_SERVICE_URL="http://ledger-service:3003"
FX_SERVICE_URL="http://fx-service:3004"

# 💱 FX Rate Hardening
FX_PROVIDER_API_KEY="board-certified-test-key"

# 📊 Observability (Otel/Jaeger)
OTEL_SERVICE_NAME="transaction-service"
OTEL_EXPORTER_OTLP_ENDPOINT="http://jaeger:4318"
