{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@novapay/types": [
                "packages/types/src"
            ],
            "@novapay/db": [
                "packages/db/src"
            ]
        }
    }
}